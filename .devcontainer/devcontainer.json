{
  "name": "MyDay2 Cloud Workspace",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspace",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "Prisma.prisma",
        "esbenp.prettier-vscode",
        "dbaeumer.vscode-eslint"
      ]
    }
  },
  "postCreateCommand": "npm install && npx prisma generate && npx prisma db push",
  "forwardPorts": [3000, 5432],
  "portsAttributes": {
    "3000": {
      "label": "MyDay2 App",
      "onAutoForward": "notify"
    }
  }
}
